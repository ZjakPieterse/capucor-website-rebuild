# Supabase — from your project dashboard: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # SECRET — never expose in client code

# Cache revalidation — any long random string (openssl rand -hex 32)
REVALIDATE_SECRET=

# Lead notifications (optional — logs to Vercel console if absent)
RESEND_API_KEY=
OWNER_NOTIFICATION_EMAIL=           # e.g. zjak@capucor.com

# Booking/calendar URL (used in Navbar CTA, portal, and onboarding pages)
NEXT_PUBLIC_BOOKING_URL=            # e.g. https://calendar.app.google/ixopmxLuGgNH5Lkk8

# Preview gate for pre-launch stub pages (/client-portal, /onboarding) — any long random string.
# Visit /client-portal?preview=<value> to bypass the "Coming soon" notice in production.
# Leave blank to keep the stubs hidden from all production traffic.
PORTAL_PREVIEW_SECRET=
